<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#97D1FF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:background="#97D1FF"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:text="💬"
                android:textSize="20sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="InterviewPro"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- Category -->

        <TextView
            android:id="@+id/txtCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Technical - Intermediate"
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:layout_marginTop="24dp"/>

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generating AI Questions..."
            android:textAlignment="center"
            android:textColor="@color/black"
            android:layout_marginTop="8dp"/>

        <ProgressBar
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="15dp"/>

        <!-- Main Card -->

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INSTRUCTIONS"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/black"/>

                <TextView
                    android:id="@+id/txtQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Click Next to generate AI questions"
                    android:textSize="24sp"
                    android:layout_marginTop="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your answer will appear here"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:textColor="@color/black"
                    android:layout_marginTop="20dp"/>

                <EditText
                    android:id="@+id/etAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:layout_marginTop="10dp"
                    android:background="@android:drawable/edit_text"
                    android:gravity="top"
                    android:hint="Type your answer here..."
                    android:inputType="textMultiLine"
                    android:padding="12dp"/>

                <!--<TextView
                    android:id="@+id/txtAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Your Answer Will Appear Here"
                    android:textAlignment="center"
                    android:textColor="#888888"
                    android:layout_marginTop="12dp"
                    android:padding="12dp"
                    android:background="@android:drawable/edit_text"/>-->

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Buttons -->

        <Button
            android:id="@+id/btnSpeak"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:text="🎙 Start Speaking"
            android:textAllCaps="false"
            android:backgroundTint="#009688"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:text="Next Question"
            android:textAllCaps="false"
            android:backgroundTint="#2196F3"/>

        <Button
            android:id="@+id/btnEndInterview"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp"
            android:text="End Interview"
            android:textAllCaps="false"
            android:backgroundTint="#FF0054"/>

    </LinearLayout>

</ScrollView>